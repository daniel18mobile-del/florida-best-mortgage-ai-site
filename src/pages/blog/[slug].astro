---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { blogPostingSchema, breadcrumbSchema, mortgageBrokerSchema } from '@utils/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postUrl = new URL(`/blog/${post.data.slug}/`, site.url).toString();
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  }).format(date);
---

<BaseLayout
  title={post.data.seo.title}
  description={post.data.seo.description}
  canonical={post.data.seo.canonical}
  ogImage={post.data.seo.ogImage}
  ogType="article"
  schema={[
    mortgageBrokerSchema(),
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Blog', url: new URL('/blog/', site.url).toString() },
      { name: post.data.title, url: postUrl }
    ]),
    blogPostingSchema({
      title: post.data.title,
      description: post.data.description,
      url: postUrl,
      publishDate: post.data.publishDate,
      updatedDate: post.data.updatedDate
    })
  ]}
>
  <Hero
    eyebrow={`Published ${formatDate(post.data.publishDate)}`}
    title={post.data.title}
    lead={post.data.description}
    primaryHref="/contact/"
    primaryLabel="Ask a mortgage question"
    secondaryHref="/blog/"
    secondaryLabel="Back to blog"
  />

  <section class="section post-content" aria-label={`${post.data.title} article`}>
    <div class="container post-content__inner">
      {post.data.tags.length > 0 && (
        <ul class="post-content__tags" aria-label={`${post.data.title} tags`}>
          {post.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>
      )}
      {post.data.updatedDate && (
        <p class="post-content__updated">Updated {formatDate(post.data.updatedDate)}</p>
      )}
      <Content />
    </div>
  </section>

  <CtaBand
    title="Need guidance for your own mortgage timeline?"
    text="Maria can help you review documents, preapproval questions, and loan options before you make your next move."
    primaryHref="/contact/"
    primaryLabel="Contact Maria"
    secondaryHref={site.phoneHref}
    secondaryLabel={`Call ${site.phone}`}
  />

  <ContactPanel />
</BaseLayout>

<style>
  .post-content {
    background: #ffffff;
  }

  .post-content__inner {
    max-width: 820px;
  }

  .post-content__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0 0 24px;
    padding: 0;
    list-style: none;
  }

  .post-content__tags li {
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-soft);
    color: var(--color-muted);
    font-size: 0.86rem;
    font-weight: 750;
    padding: 0.35rem 0.55rem;
  }

  .post-content__updated {
    color: var(--color-muted);
    font-size: 0.95rem;
    font-weight: 750;
  }

  .post-content__inner :global(h2) {
    margin: 2.2rem 0 0.8rem;
    font-size: clamp(1.55rem, 3vw, 2.25rem);
    line-height: 1.12;
  }

  .post-content__inner :global(p) {
    color: var(--color-muted);
    font-size: 1.05rem;
  }
</style>
