---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import FaqList from '@components/FaqList.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { faqSchema, mortgageBrokerSchema } from '@utils/schema';

export async function getStaticPaths() {
  const locations = await getCollection('locations');

  return locations.map((location) => ({
    params: { slug: location.data.slug },
    props: { location }
  }));
}

const { location } = Astro.props;
const { Content } = await render(location);
const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order);
const schema = location.data.faqs.length > 0
  ? [mortgageBrokerSchema(), faqSchema(location.data.faqs)]
  : mortgageBrokerSchema();
---

<BaseLayout
  title={location.data.seo.title}
  description={location.data.seo.description}
  canonical={location.data.seo.canonical}
  ogImage={location.data.seo.ogImage}
  schema={schema}
>
  <Hero
    eyebrow={`${location.data.city}, ${location.data.region}`}
    title={location.data.title}
    lead={location.data.summary}
    primaryHref="/contact/"
    primaryLabel="Ask about local mortgage options"
    secondaryHref={site.phoneHref}
    secondaryLabel={`Call ${site.phone}`}
  />

  <section class="section content-section" aria-label={`${location.data.title} details`}>
    <div class="container content-section__inner">
      <Content />
    </div>
  </section>

  <section class="section service-links" aria-labelledby="service-links-heading">
    <div class="container">
      <div class="service-links__header">
        <p class="eyebrow">Mortgage options</p>
        <h2 id="service-links-heading">Services available in {location.data.city}</h2>
        <p class="lead">Review common loan paths for local buyers and homeowners.</p>
      </div>
      <div class="grid">
        {services.map((service) => (
          <article class="card service-link">
            <h3><a href={`/services/${service.data.slug}/`}>{service.data.title}</a></h3>
            <p>{service.data.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <FaqList
    eyebrow="Local questions"
    title={`${location.data.city} mortgage FAQs`}
    lead="Local property details, borrower qualifications, and lender requirements can affect the loan path."
    faqs={location.data.faqs}
  />

  <ContactPanel
    title={`Talk with Maria about a mortgage in ${location.data.city}`}
    text={`Get practical ${location.data.city} mortgage guidance for buying, refinancing, or comparing home equity options.`}
  />
</BaseLayout>

<style>
  .content-section {
    background: #ffffff;
  }

  .content-section__inner {
    max-width: 820px;
  }

  .content-section__inner :global(h2) {
    margin: 2.2rem 0 0.8rem;
    font-size: clamp(1.55rem, 3vw, 2.25rem);
    line-height: 1.12;
  }

  .content-section__inner :global(p) {
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .service-links {
    background: var(--color-soft);
  }

  .service-links__header {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .service-links__header h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .service-links__header .lead {
    margin: 14px 0 0;
  }

  .service-link h3,
  .service-link p {
    margin: 0;
  }

  .service-link {
    display: grid;
    gap: 12px;
  }

  .service-link h3 {
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .service-link h3 a {
    text-decoration: none;
  }

  .service-link p {
    color: var(--color-muted);
  }
</style>
