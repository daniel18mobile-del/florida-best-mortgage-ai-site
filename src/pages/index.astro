---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { heroMedia, serviceImages } from '@data/media';
import { mortgageBrokerSchema } from '@utils/schema';

const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((service) => ({
    title: service.data.title,
    summary: service.data.summary,
    href: `/services/${service.data.slug}/`,
    ctaLabel: service.data.ctaLabel,
    image: serviceImages[service.data.slug]
  }));
const locations = (await getCollection('locations'))
  .sort((a, b) => a.data.city.localeCompare(b.data.city));
---

<BaseLayout
  title="Florida Mortgage Broker"
  description="Florida Best Mortgage helps buyers and homeowners compare purchase, refinance, FHA, VA, first-time buyer, and home equity loan options with Maria Zuluaga."
  schema={mortgageBrokerSchema()}
>
  <Hero
    eyebrow="Florida mortgage guidance"
    title="Mortgage help for Florida buyers and homeowners"
    lead={`Work with ${site.advisor.name} for practical loan guidance, clear next steps, and support from preapproval through closing.`}
    primaryHref="/contact/"
    primaryLabel="Talk with Maria"
    secondaryHref="/services/"
    secondaryLabel="Explore loan options"
    videoSrc={heroMedia.videoSrc}
    posterSrc={heroMedia.posterSrc}
  />

  <ServiceGrid
    eyebrow="Loan options"
    title="Mortgage services built around your next move"
    lead="Compare programs, documents, payments, and timelines before you commit to a loan path."
    services={services}
  />

  <section class="trust-strip" aria-label="Florida Best Mortgage highlights">
    <div class="container trust-strip__inner">
      <div>
        <strong>Florida licensed guidance</strong>
        <span>{site.nmls}</span>
      </div>
      <div>
        <strong>Purchase and refinance</strong>
        <span>FHA, VA, first-time buyer, refinance, and home equity support.</span>
      </div>
      <div>
        <strong>Local and bilingual</strong>
        <span>Naples-based help available in English and Spanish.</span>
      </div>
    </div>
  </section>

  <section class="section local-links" id="southwest-florida-mortgage-support" aria-labelledby="local-links-heading">
    <div class="container local-links__inner">
      <div>
        <p class="eyebrow">Local guidance</p>
        <h2 id="local-links-heading">Southwest Florida mortgage support</h2>
        <p class="lead">
          Get local help with property types, insurance questions, condo considerations, and offer timelines in key Florida markets.
        </p>
      </div>
      <div class="local-links__list">
        {locations.map((location) => (
          <a class="card local-link" href={`/locations/${location.data.slug}/`}>
            <span>{location.data.title}</span>
            <small>{location.data.summary}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    title="Ready to talk through your mortgage options?"
    text="Call or email for purchase, refinance, home equity, and first-time buyer guidance in Florida."
    primaryHref={site.phoneHref}
    primaryLabel={`Call ${site.phone}`}
    secondaryHref="/contact/"
    secondaryLabel="Contact Florida Best Mortgage"
  />

  <ContactPanel />
</BaseLayout>

<style>
  .trust-strip {
    background: #ffffff;
    border-block: 1px solid var(--color-line);
  }

  .trust-strip__inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--color-line);
  }

  .trust-strip__inner > div {
    display: grid;
    gap: 6px;
    background: #ffffff;
    padding: clamp(18px, 3vw, 26px);
  }

  .trust-strip strong {
    color: var(--color-primary-dark);
    font-size: 1.05rem;
  }

  .trust-strip span {
    color: var(--color-muted);
    font-size: 0.94rem;
  }

  .local-links {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(245, 248, 251, 0.94)),
      var(--color-soft);
  }

  .local-links__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(24px, 5vw, 56px);
    align-items: start;
  }

  .local-links h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .local-links .lead {
    margin: 14px 0 0;
  }

  .local-links__list {
    display: grid;
    gap: 16px;
  }

  .local-link {
    display: grid;
    gap: 8px;
    text-decoration: none;
  }

  .local-link span {
    font-size: 1.12rem;
    font-weight: 850;
  }

  .local-link small {
    color: var(--color-muted);
    font-size: 0.98rem;
  }

  @media (max-width: 820px) {
    .trust-strip__inner {
      grid-template-columns: 1fr;
    }

    .local-links__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
