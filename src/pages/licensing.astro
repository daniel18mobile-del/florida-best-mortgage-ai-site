---
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { mortgageBrokerSchema, webPageSchema } from '@utils/schema';

const title = 'Licensing and Trust';
const description = 'Review Dinerofacil LLC licensing, NMLS identifiers, contact information, and compliance notes for Florida mortgage guidance from Maria Zuluaga.';
const schema = [
  mortgageBrokerSchema(),
  webPageSchema({
    name: `${title} | ${site.name}`,
    description,
    url: `${site.url}/licensing/`
  })
];
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
>
  <section class="section trust-page" aria-labelledby="trust-heading">
    <div class="container trust-page__inner">
      <div class="trust-page__intro">
        <p class="eyebrow">Licensing and trust</p>
        <h1 id="trust-heading">Verify who you are working with</h1>
        <p class="lead">
          Dinerofacil LLC keeps licensing, compliance, and clear borrower expectations visible so buyers and homeowners can make informed decisions before applying.
        </p>
      </div>

      <div class="grid trust-page__cards">
        <article class="card">
          <h2>Advisor</h2>
          <p>{site.advisor.name}</p>
          <p>NMLS #{site.advisor.nmls}</p>
        </article>
        <article class="card">
          <h2>Company</h2>
          <p>{site.legalName}</p>
          <p>NMLS #{site.companyNmls}</p>
        </article>
        <article class="card">
          <h2>Public lookup</h2>
          <p>
            Use NMLS Consumer Access to search by name or NMLS number and review public licensing information.
          </p>
          <a href={site.nmlsConsumerAccessUrl} rel="noopener noreferrer">Open NMLS Consumer Access</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section compliance-notes" aria-labelledby="compliance-notes-heading">
    <div class="container compliance-notes__inner">
      <div>
        <p class="eyebrow">Borrower expectations</p>
        <h2 id="compliance-notes-heading">Clear guidance, no unsupported promises</h2>
      </div>
      <div class="compliance-notes__copy">
        <p>
          Information on this website is for general educational purposes and is not a commitment to lend, extend credit, or guarantee a specific rate, term, payment, or approval.
        </p>
        <p>
          Final loan options depend on borrower qualification, property details, documentation, lender review, program availability, and applicable underwriting guidelines.
        </p>
        <p>
          Contact Maria directly before making a financing decision, changing employment, moving funds, opening new credit, or relying on an estimated payment.
        </p>
      </div>
    </div>
  </section>

  <CtaBand
    title="Talk through your mortgage questions"
    text="Get guidance on documents, loan options, and next steps before you move forward."
    primaryHref={site.phoneHref}
    primaryLabel={`Call ${site.phone}`}
    secondaryHref="/contact/"
    secondaryLabel="Contact Dinerofacil LLC"
  />

  <ContactPanel />
</BaseLayout>

<style>
  .trust-page {
    background:
      linear-gradient(135deg, rgba(13, 88, 112, 0.08), rgba(191, 122, 37, 0.1)),
      #ffffff;
  }

  .trust-page__inner,
  .compliance-notes__inner {
    display: grid;
    gap: 30px;
  }

  .trust-page__intro {
    max-width: 820px;
  }

  .trust-page h1,
  .compliance-notes h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.02;
  }

  .trust-page .lead {
    margin: 16px 0 0;
  }

  .trust-page__cards h2,
  .trust-page__cards p,
  .compliance-notes__copy p {
    margin: 0;
  }

  .trust-page__cards .card {
    display: grid;
    gap: 10px;
  }

  .trust-page__cards h2 {
    font-size: 1.05rem;
  }

  .trust-page__cards p,
  .compliance-notes__copy p {
    color: var(--color-muted);
  }

  .trust-page__cards a {
    color: var(--color-primary);
    font-weight: 850;
  }

  .compliance-notes {
    background: #ffffff;
  }

  .compliance-notes__inner {
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1fr);
    align-items: start;
    gap: clamp(24px, 5vw, 56px);
  }

  .compliance-notes__copy {
    display: grid;
    gap: 16px;
  }

  @media (max-width: 820px) {
    .compliance-notes__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
