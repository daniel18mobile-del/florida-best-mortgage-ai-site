---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import FaqList from '@components/FaqList.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { breadcrumbSchema, faqSchema, mortgageBrokerSchema } from '@utils/schema';

export async function getStaticPaths() {
  const services = await getCollection('services');

  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const serviceUrl = new URL(`/services/${service.data.slug}/`, site.url).toString();
const schema = service.data.faqs.length > 0
  ? [
      mortgageBrokerSchema(),
      breadcrumbSchema([
        { name: 'Home', url: site.url },
        { name: 'Services', url: new URL('/services/', site.url).toString() },
        { name: service.data.title, url: serviceUrl }
      ]),
      faqSchema(service.data.faqs)
    ]
  : [
      mortgageBrokerSchema(),
      breadcrumbSchema([
        { name: 'Home', url: site.url },
        { name: 'Services', url: new URL('/services/', site.url).toString() },
        { name: service.data.title, url: serviceUrl }
      ])
    ];
---

<BaseLayout
  title={service.data.seo.title}
  description={service.data.seo.description}
  canonical={service.data.seo.canonical}
  ogImage={service.data.seo.ogImage}
  schema={schema}
>
  <Hero
    eyebrow="Mortgage service"
    title={service.data.title}
    lead={service.data.summary}
    primaryHref="/contact/"
    primaryLabel={service.data.ctaLabel}
    secondaryHref={site.phoneHref}
    secondaryLabel={`Call ${site.phone}`}
  />

  <section class="section content-section" aria-label={`${service.data.title} details`}>
    <div class="container content-section__inner">
      <Content />
    </div>
  </section>

  <FaqList
    eyebrow="Questions"
    title={`${service.data.title} FAQs`}
    lead="Answers are general guidance. Final loan terms and approvals depend on borrower, property, program, and lender requirements."
    faqs={service.data.faqs}
  />

  <CtaBand
    title={`Talk through ${service.data.title.toLowerCase()}`}
    text="Get practical guidance on documents, eligibility, payments, and next steps before you apply."
    primaryHref="/contact/"
    primaryLabel="Contact Florida Best Mortgage"
    secondaryHref={site.phoneHref}
    secondaryLabel={`Call ${site.phone}`}
  />

  <ContactPanel />
</BaseLayout>

<style>
  .content-section {
    background: #ffffff;
  }

  .content-section__inner {
    max-width: 820px;
  }

  .content-section__inner :global(h2) {
    margin: 2.2rem 0 0.8rem;
    font-size: clamp(1.55rem, 3vw, 2.25rem);
    line-height: 1.12;
  }

  .content-section__inner :global(p) {
    color: var(--color-muted);
    font-size: 1.05rem;
  }
</style>
