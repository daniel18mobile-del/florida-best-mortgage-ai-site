---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { heroMedia, serviceImages } from '@data/media';
import { site } from '@data/site';
import { getSpanishServiceCopy } from '@data/spanish';
import { breadcrumbSchema, mortgageBrokerSchema } from '@utils/schema';

const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((service) => {
    const copy = getSpanishServiceCopy(service.data.slug, {
      title: service.data.title,
      summary: service.data.summary
    });

    return {
      title: copy.title,
      summary: copy.summary,
      href: `/es/services/${service.data.slug}/`,
      ctaLabel: 'Ver opciones',
      image: serviceImages[service.data.slug]
    };
  });

const locations = (await getCollection('locations'))
  .sort((a, b) => a.data.city.localeCompare(b.data.city))
  .map((location) => ({
    city: location.data.city,
    title: `Hipotecas en ${location.data.city}`,
    summary: `Orientacion local para compradores y propietarios en ${location.data.city}, Florida.`,
    href: `/locations/${location.data.slug}/`
  }));
---

<BaseLayout
  title="Hipotecas en Florida en Espanol"
  description="Dinerofacil LLC ofrece orientacion hipotecaria en espanol para compra, refinanciamiento, FHA, VA, primeros compradores, HELOC y opciones en Southwest Florida."
  schema={[
    mortgageBrokerSchema({
      description:
        'Orientacion hipotecaria en Florida para compradores, propietarios, veteranos y personas que desean comparar opciones de prestamo en espanol.'
    }),
    breadcrumbSchema([
      { name: 'Inicio', url: site.url },
      { name: 'Espanol', url: new URL('/es/', site.url).toString() }
    ])
  ]}
>
  <Hero
    eyebrow="Orientacion hipotecaria en Florida"
    title="Ayuda hipotecaria para compradores y propietarios"
    lead={`Trabaje con ${site.advisor.name} para recibir orientacion practica, proximos pasos claros y apoyo desde la preaprobacion hasta el cierre.`}
    primaryHref="/es/contact/"
    primaryLabel="Hablar con Maria"
    secondaryHref="/es/services/"
    secondaryLabel="Explorar opciones"
    videoSrc={heroMedia.videoSrc}
    posterSrc={heroMedia.posterSrc}
  />

  <ServiceGrid
    eyebrow="Opciones de prestamo"
    title="Servicios hipotecarios para su proximo paso"
    lead="Compare programas, documentos, pagos estimados y tiempos antes de escoger una opcion de prestamo."
    services={services}
  />

  <section class="trust-strip" aria-label="Puntos destacados de Dinerofacil LLC">
    <div class="container trust-strip__inner">
      <div>
        <strong>Orientacion con licencia en Florida</strong>
        <span>{site.nmls}</span>
      </div>
      <div>
        <strong>Compra y refinanciamiento</strong>
        <span>Apoyo para FHA, VA, primeros compradores, refinanciamiento y home equity.</span>
      </div>
      <div>
        <strong>Local y bilingue</strong>
        <span>Ayuda desde Naples disponible en ingles y espanol.</span>
      </div>
    </div>
  </section>

  <section class="section local-links" id="southwest-florida-mortgage-support" aria-labelledby="local-links-heading">
    <div class="container local-links__inner">
      <div>
        <p class="eyebrow">Guia local</p>
        <h2 id="local-links-heading">Apoyo hipotecario en Southwest Florida</h2>
        <p class="lead">
          Reciba ayuda local con tipos de propiedad, seguros, condominios y tiempos de oferta en mercados importantes de Florida.
        </p>
      </div>
      <div class="local-links__list">
        {locations.map((location) => (
          <a class="card local-link" href={location.href}>
            <span>{location.title}</span>
            <small>{location.summary}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    title="Listo para revisar sus opciones hipotecarias?"
    text="Llame o envie un correo para orientacion sobre compra, refinanciamiento, home equity y primeros compradores en Florida."
    primaryHref={site.phoneHref}
    primaryLabel={`Llamar ${site.phone}`}
    secondaryHref="/es/contact/"
    secondaryLabel="Contactar a Dinerofacil LLC"
  />

  <ContactPanel
    title="Hablemos de sus opciones hipotecarias"
    text="Maria puede ayudarle a entender documentos, pagos estimados, requisitos del prestamo y proximos pasos en ingles o espanol."
  />
</BaseLayout>

<style>
  .trust-strip {
    background: #ffffff;
    border-block: 1px solid var(--color-line);
  }

  .trust-strip__inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--color-line);
  }

  .trust-strip__inner > div {
    display: grid;
    gap: 6px;
    background: #ffffff;
    padding: clamp(18px, 3vw, 26px);
  }

  .trust-strip strong {
    color: var(--color-primary-dark);
    font-size: 1.05rem;
  }

  .trust-strip span {
    color: var(--color-muted);
    font-size: 0.94rem;
  }

  .local-links {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(245, 248, 251, 0.94)),
      var(--color-soft);
  }

  .local-links__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(24px, 5vw, 56px);
    align-items: start;
  }

  .local-links h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .local-links .lead {
    margin: 14px 0 0;
  }

  .local-links__list {
    display: grid;
    gap: 16px;
  }

  .local-link {
    display: grid;
    gap: 8px;
    text-decoration: none;
  }

  .local-link span {
    font-size: 1.12rem;
    font-weight: 850;
  }

  .local-link small {
    color: var(--color-muted);
    font-size: 0.98rem;
  }

  @media (max-width: 820px) {
    .trust-strip__inner {
      grid-template-columns: 1fr;
    }

    .local-links__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
