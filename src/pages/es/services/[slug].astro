---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import FaqList from '@components/FaqList.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { breadcrumbSchema, faqSchema, mortgageBrokerSchema } from '@utils/schema';

export async function getStaticPaths() {
  const services = await getCollection('services');

  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const spanishUrl = new URL(`/es/services/${service.data.slug}/`, site.url).toString();
const schema = [
  mortgageBrokerSchema(),
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Espanol', url: new URL('/es/', site.url).toString() },
    { name: 'Servicios', url: new URL('/es/services/', site.url).toString() },
    { name: service.data.title, url: spanishUrl }
  ]),
  ...(service.data.faqs.length > 0 ? [faqSchema(service.data.faqs)] : [])
];
---

<BaseLayout
  title={`${service.data.title} en Espanol`}
  description={`Orientacion en espanol sobre ${service.data.title.toLowerCase()} con Dinerofacil LLC, incluyendo documentos, requisitos, pago estimado y proximos pasos.`}
  canonical={`/es/services/${service.data.slug}/`}
  schema={schema}
>
  <Hero
    eyebrow="Servicio hipotecario"
    title={`${service.data.title} en Florida`}
    lead="Maria puede explicarle esta opcion hipotecaria en espanol y ayudarle a comparar documentos, requisitos, pago estimado y alternativas."
    primaryHref="/contact/"
    primaryLabel="Contactar a Maria"
    secondaryHref={site.phoneHref}
    secondaryLabel={`Llamar ${site.phone}`}
  />

  <section class="section content-section" aria-label={`${service.data.title} en espanol`}>
    <div class="container content-section__inner">
      <h2>Ayuda en espanol</h2>
      <p>{service.data.summary}</p>
      <p>
        Cada prestamo depende del prestatario, la propiedad, el programa, el prestamista y las reglas de aprobacion. Dinerofacil LLC puede ayudarle a entender que documentos preparar y que preguntas hacer antes de aplicar.
      </p>
      <h2>Proximos pasos</h2>
      <p>
        Llame o envie un mensaje para revisar su objetivo, ingreso, credito, fondos disponibles, tipo de propiedad y fecha estimada de cierre. Tambien puede leer la pagina principal en ingles para mas detalles.
      </p>
      <p><a href={`/services/${service.data.slug}/`}>Ver detalles en ingles sobre {service.data.title}</a></p>
    </div>
  </section>

  <FaqList
    eyebrow="Preguntas"
    title={`Preguntas sobre ${service.data.title}`}
    lead="Estas respuestas son informacion general. La aprobacion final depende de requisitos del programa, propiedad, prestatario y prestamista."
    faqs={service.data.faqs}
  />

  <ContactPanel
    title={`Hable con Maria sobre ${service.data.title}`}
    text="Reciba orientacion clara en ingles o espanol antes de escoger un camino hipotecario."
  />
</BaseLayout>

<style>
  .content-section {
    background: #ffffff;
  }

  .content-section__inner {
    max-width: 820px;
  }

  .content-section__inner h2 {
    margin: 2.2rem 0 0.8rem;
    font-size: clamp(1.55rem, 3vw, 2.25rem);
    line-height: 1.12;
  }

  .content-section__inner p {
    color: var(--color-muted);
    font-size: 1.05rem;
  }
</style>
