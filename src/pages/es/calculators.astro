---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CtaBand from '@components/CtaBand.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { breadcrumbSchema, mortgageBrokerSchema } from '@utils/schema';

const tools = [
  {
    title: 'Estimado de pago hipotecario',
    text: 'Calcule principal e interes antes de revisar impuestos, seguro de vivienda, seguro hipotecario, HOA y seguro contra inundacion.'
  },
  {
    title: 'Punto de equilibrio de refinanciamiento',
    text: 'Compare ahorros estimados con costos de cierre y el tiempo que espera mantener el prestamo.'
  },
  {
    title: 'Resumen de home equity',
    text: 'Organice preguntas sobre HELOC, home equity loan y cash-out refinance antes de escoger una opcion.'
  }
];
---

<BaseLayout
  title="Calculadoras Hipotecarias en Florida"
  description="Use calculadoras hipotecarias en espanol para preparar preguntas sobre pagos, refinanciamiento, home equity, seguros y efectivo para cerrar."
  schema={[
    mortgageBrokerSchema(),
    breadcrumbSchema([
      { name: 'Espanol', url: new URL('/es/', site.url).toString() },
      { name: 'Calculadoras', url: new URL('/es/calculators/', site.url).toString() }
    ])
  ]}
>
  <Hero
    eyebrow="Calculadoras hipotecarias"
    title="Estime los numeros antes de escoger un prestamo"
    lead="Las calculadoras son un punto de partida. En Florida, el pago puede cambiar con impuestos, seguros, flood insurance, HOA, condominio y reglas del programa."
    primaryHref="#mortgage-tools-heading"
    primaryLabel="Usar calculadoras"
    secondaryHref="/es/contact/"
    secondaryLabel="Revisar con Maria"
  />

  <section class="section mortgage-tools" aria-labelledby="mortgage-tools-heading">
    <div class="container mortgage-tools__inner">
      <div class="mortgage-tools__header">
        <p class="eyebrow">Herramientas</p>
        <h2 id="mortgage-tools-heading">Calcule el estimado</h2>
        <p class="lead">
          Estos calculos son solo para planificar. Impuestos, seguros, mortgage insurance, HOA, credito, tipo de propiedad y revision del lender pueden cambiar el resultado final.
        </p>
      </div>

      <div class="mortgage-tools__grid">
        <article class="card tool-card" aria-labelledby="payment-calculator-heading">
          <h3 id="payment-calculator-heading">Estimado de pago</h3>
          <div class="tool-card__fields">
            <label>
              Precio de compra
              <input id="purchase-price" type="number" min="0" step="1000" value="450000" inputmode="decimal" />
            </label>
            <label>
              Pago inicial
              <input id="down-payment" type="number" min="0" step="1000" value="45000" inputmode="decimal" />
            </label>
            <label>
              Tasa de interes
              <input id="interest-rate" type="number" min="0" step="0.125" value="6.75" inputmode="decimal" />
            </label>
            <label>
              Plazo
              <select id="loan-term">
                <option value="30" selected>30 anos</option>
                <option value="20">20 anos</option>
                <option value="15">15 anos</option>
                <option value="10">10 anos</option>
              </select>
            </label>
            <label>
              Impuesto anual
              <input id="annual-tax" type="number" min="0" step="100" value="5200" inputmode="decimal" />
            </label>
            <label>
              Seguro anual
              <input id="annual-insurance" type="number" min="0" step="100" value="3600" inputmode="decimal" />
            </label>
            <label>
              HOA/condominio mensual
              <input id="monthly-hoa" type="number" min="0" step="25" value="0" inputmode="decimal" />
            </label>
          </div>
          <div class="tool-card__result" aria-live="polite">
            <span>Pago mensual estimado</span>
            <strong id="payment-result">$0</strong>
            <small id="payment-breakdown">Principal e interes mas impuestos, seguro y HOA ingresados.</small>
          </div>
        </article>

        <article class="card tool-card" aria-labelledby="refinance-calculator-heading">
          <h3 id="refinance-calculator-heading">Refinanciamiento</h3>
          <div class="tool-card__fields">
            <label>
              Pago mensual actual
              <input id="current-payment" type="number" min="0" step="25" value="3200" inputmode="decimal" />
            </label>
            <label>
              Nuevo pago mensual
              <input id="new-payment" type="number" min="0" step="25" value="2900" inputmode="decimal" />
            </label>
            <label>
              Costos de cierre estimados
              <input id="closing-costs" type="number" min="0" step="100" value="6500" inputmode="decimal" />
            </label>
          </div>
          <div class="tool-card__result" aria-live="polite">
            <span>Punto de equilibrio</span>
            <strong id="refi-result">0 meses</strong>
            <small id="refi-breakdown">Basado en ahorros mensuales antes de otros factores.</small>
          </div>
        </article>

        <article class="card tool-card" aria-labelledby="equity-calculator-heading">
          <h3 id="equity-calculator-heading">Home equity</h3>
          <div class="tool-card__fields">
            <label>
              Valor estimado de la casa
              <input id="home-value" type="number" min="0" step="1000" value="550000" inputmode="decimal" />
            </label>
            <label>
              Balance actual de hipoteca
              <input id="mortgage-balance" type="number" min="0" step="1000" value="325000" inputmode="decimal" />
            </label>
            <label>
              LTV combinado objetivo
              <input id="target-ltv" type="number" min="0" max="100" step="1" value="80" inputmode="decimal" />
            </label>
          </div>
          <div class="tool-card__result" aria-live="polite">
            <span>Equity disponible estimado</span>
            <strong id="equity-result">$0</strong>
            <small id="equity-breakdown">Sujeto a limites del lender, revision de propiedad, credito, ingreso y programa.</small>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section calculator-guide" aria-labelledby="calculator-guide-heading">
    <div class="container">
      <div class="calculator-guide__header">
        <p class="eyebrow">Planificacion</p>
        <h2 id="calculator-guide-heading">Que calcular primero</h2>
        <p class="lead">Use estos estimados para prepararse para una conversacion mas precisa de preaprobacion o refinanciamiento.</p>
      </div>
      <div class="grid">
        {tools.map((tool) => (
          <article class="card calculator-card">
            <h3>{tool.title}</h3>
            <p>{tool.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    title="Quiere revisar un pago mas claro?"
    text="Comparta sus metas y detalles de la propiedad para comparar opciones realistas."
    primaryHref="/es/contact/"
    primaryLabel="Pedir revision"
    secondaryHref={site.phoneHref}
    secondaryLabel={`Llamar ${site.phone}`}
  />

  <ContactPanel
    title="Hable con Maria Zuluaga"
    text="Reciba orientacion en espanol para compra, refinanciamiento o preguntas de home equity en Florida."
  />
</BaseLayout>

<style>
  .calculator-guide {
    background: var(--color-soft);
  }

  .calculator-guide__header {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .calculator-guide__header h2 {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    line-height: 1.08;
  }

  .calculator-guide__header .lead {
    margin: 14px 0 0;
  }

  .calculator-card {
    display: grid;
    gap: 12px;
  }

  .calculator-card h3,
  .calculator-card p {
    margin: 0;
  }

  .calculator-card p {
    color: var(--color-muted);
  }

  .mortgage-tools {
    background: #ffffff;
  }

  .mortgage-tools__inner {
    display: grid;
    gap: 28px;
  }

  .mortgage-tools__header {
    max-width: 820px;
  }

  .mortgage-tools__header h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .mortgage-tools__header .lead {
    margin: 14px 0 0;
  }

  .mortgage-tools__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 24px;
    align-items: start;
  }

  .tool-card {
    display: grid;
    gap: 18px;
  }

  .tool-card h3 {
    margin: 0;
    font-size: 1.25rem;
  }

  .tool-card__fields {
    display: grid;
    gap: 14px;
  }

  .tool-card__result {
    display: grid;
    gap: 6px;
    border-radius: var(--radius);
    background: #eef5f8;
    padding: 18px;
  }

  .tool-card__result span {
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .tool-card__result strong {
    color: var(--color-primary-dark);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    line-height: 1;
  }

  .tool-card__result small {
    color: var(--color-muted);
  }
</style>

<script>
  const currency = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0
  });

  const numberValue = (id: string) => {
    const element = document.getElementById(id);
    return element instanceof HTMLInputElement || element instanceof HTMLSelectElement
      ? Number(element.value) || 0
      : 0;
  };

  const setText = (id: string, value: string) => {
    const element = document.getElementById(id);
    if (element) element.textContent = value;
  };

  function calculatePayment() {
    const price = numberValue('purchase-price');
    const downPayment = numberValue('down-payment');
    const principal = Math.max(price - downPayment, 0);
    const annualRate = numberValue('interest-rate') / 100;
    const months = numberValue('loan-term') * 12;
    const monthlyRate = annualRate / 12;
    const principalAndInterest = monthlyRate > 0
      ? principal * (monthlyRate * (1 + monthlyRate) ** months) / ((1 + monthlyRate) ** months - 1)
      : principal / Math.max(months, 1);
    const taxes = numberValue('annual-tax') / 12;
    const insurance = numberValue('annual-insurance') / 12;
    const hoa = numberValue('monthly-hoa');
    const total = principalAndInterest + taxes + insurance + hoa;

    setText('payment-result', currency.format(total));
    setText(
      'payment-breakdown',
      `${currency.format(principalAndInterest)} principal e interes + ${currency.format(taxes)} impuestos + ${currency.format(insurance)} seguro + ${currency.format(hoa)} HOA.`
    );
  }

  function calculateRefinance() {
    const savings = numberValue('current-payment') - numberValue('new-payment');
    const costs = numberValue('closing-costs');
    if (savings <= 0) {
      setText('refi-result', 'Sin ahorro mensual');
      setText('refi-breakdown', 'El nuevo pago no es mas bajo que el pago actual con estos numeros.');
      return;
    }

    const months = Math.ceil(costs / savings);
    setText('refi-result', `${months} meses`);
    setText('refi-breakdown', `${currency.format(costs)} costos / ${currency.format(savings)} ahorro mensual.`);
  }

  function calculateEquity() {
    const value = numberValue('home-value');
    const balance = numberValue('mortgage-balance');
    const targetLtv = numberValue('target-ltv') / 100;
    const maxDebt = value * targetLtv;
    const available = Math.max(maxDebt - balance, 0);

    setText('equity-result', currency.format(available));
    setText('equity-breakdown', `A ${Math.round(targetLtv * 100)}% LTV combinado, deuda maxima estimada ${currency.format(maxDebt)} antes de revision.`);
  }

  function updateCalculators() {
    calculatePayment();
    calculateRefinance();
    calculateEquity();
  }

  document.querySelectorAll('.mortgage-tools input, .mortgage-tools select').forEach((element) => {
    element.addEventListener('input', updateCalculators);
    element.addEventListener('change', updateCalculators);
  });

  updateCalculators();
</script>
