---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { breadcrumbSchema, mortgageBrokerSchema } from '@utils/schema';
---

<BaseLayout
  title="Sobre Florida Best Mortgage en Espanol"
  description="Conozca a Maria Zuluaga y Florida Best Mortgage, con orientacion hipotecaria en ingles y espanol para compradores y propietarios en Florida."
  schema={[
    mortgageBrokerSchema(),
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Espanol', url: new URL('/es/', site.url).toString() },
      { name: 'Sobre Nosotros', url: new URL('/es/about/', site.url).toString() }
    ])
  ]}
>
  <Hero
    eyebrow="Sobre nosotros"
    title="Ayuda hipotecaria clara y bilingue"
    lead={`${site.advisor.name} ayuda a compradores y propietarios en Florida a entender opciones de prestamo, documentos, pagos estimados y proximos pasos.`}
    primaryHref="/contact/"
    primaryLabel="Contactar a Maria"
    secondaryHref={site.phoneHref}
    secondaryLabel={`Llamar ${site.phone}`}
  />

  <section class="section content-section">
    <div class="container content-section__inner">
      <h2>Florida Best Mortgage</h2>
      <p>
        Florida Best Mortgage ofrece orientacion hipotecaria para compra, refinanciamiento, FHA, VA, compradores por primera vez, HELOC, jumbo, condominios y otras situaciones de financiamiento.
      </p>
      <p>
        Maria explica el proceso en lenguaje claro para que pueda comparar opciones antes de tomar una decision.
      </p>
    </div>
  </section>

  <ContactPanel />
</BaseLayout>

<style>
  .content-section {
    background: #ffffff;
  }

  .content-section__inner {
    max-width: 820px;
  }

  .content-section__inner h2 {
    margin: 0 0 0.8rem;
    font-size: clamp(1.55rem, 3vw, 2.25rem);
  }

  .content-section__inner p {
    color: var(--color-muted);
  }
</style>
