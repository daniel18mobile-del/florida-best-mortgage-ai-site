---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ContactPanel from '@components/ContactPanel.astro';
import { site } from '@data/site';
import { breadcrumbSchema, mortgageBrokerSchema } from '@utils/schema';
---

<BaseLayout
  title="Contacto en Espanol"
  description="Contacte a Dinerofacil LLC para orientacion hipotecaria en espanol sobre compra, refinanciamiento, FHA, VA, HELOC y opciones en Florida."
  schema={[
    mortgageBrokerSchema(),
    breadcrumbSchema([
      { name: 'Home', url: site.url },
      { name: 'Espanol', url: new URL('/es/', site.url).toString() },
      { name: 'Contacto', url: new URL('/es/contact/', site.url).toString() }
    ])
  ]}
>
  <Hero
    eyebrow="Contacto"
    title="Hable con Maria sobre su hipoteca"
    lead="Llame o envie un correo para revisar sus preguntas sobre compra, refinanciamiento, preaprobacion, documentos o pagos estimados."
    primaryHref={site.phoneHref}
    primaryLabel={`Llamar ${site.phone}`}
    secondaryHref={site.emailHref}
    secondaryLabel="Enviar correo"
  />

  <ContactPanel
    title="Contacto de Dinerofacil LLC"
    text="Ayuda disponible en ingles y espanol para compradores y propietarios en Florida."
  />
</BaseLayout>
