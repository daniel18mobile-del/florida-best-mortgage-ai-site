---
import { site } from '@data/site';

type Props = {
  eyebrow?: string;
  title?: string;
  text?: string;
};

const isSpanishPage = Astro.url.pathname === '/es/' || Astro.url.pathname.startsWith('/es/');
const defaultEyebrow = isSpanishPage ? 'Contacto' : 'Contact';
const defaultTitle = isSpanishPage ? `Hable con ${site.advisor.name}` : `Talk with ${site.advisor.name}`;
const defaultText = isSpanishPage
  ? 'Reciba orientacion hipotecaria en Florida para su proxima compra, refinanciamiento o pregunta sobre home equity.'
  : 'Get Florida mortgage guidance for your next purchase, refinance, or home equity question.';
const contactCopy = isSpanishPage
  ? {
      advisorKicker: 'Asesora hipotecaria',
      detailsHeading: 'Datos de contacto',
      promptHeading: 'Inicie una conversacion hipotecaria',
      promptText:
        'Llame o envie un correo para recibir orientacion sobre opciones de prestamo, preaprobacion, refinanciamiento o home equity en Florida.',
      callLabel: `Llamar ${site.phone}`,
      emailLabel: `Enviar correo a ${site.advisor.name}`,
      emailSubject: 'Solicitud de orientacion hipotecaria en Florida',
      emailBody: `Hola ${site.advisor.name},\n\nMe gustaria recibir orientacion hipotecaria para:\n\n`
    }
  : {
      advisorKicker: 'Mortgage advisor',
      detailsHeading: 'Contact details',
      promptHeading: 'Start a mortgage conversation',
      promptText:
        'Call or email for guidance on loan options, preapproval, refinancing, or home equity questions in Florida.',
      callLabel: `Call ${site.phone}`,
      emailLabel: `Email ${site.advisor.name}`,
      emailSubject: 'Florida mortgage guidance request',
      emailBody: `Hi ${site.advisor.name},\n\nI would like mortgage guidance for:\n\n`
    };

const {
  eyebrow = defaultEyebrow,
  title = defaultTitle,
  text = defaultText
} = Astro.props;

const addressLine = `${site.address.city}, ${site.address.region} ${site.address.postalCode}`;
const emailSubject = encodeURIComponent(contactCopy.emailSubject);
const emailBody = encodeURIComponent(contactCopy.emailBody);
const guidanceEmailHref = `${site.emailHref}?subject=${emailSubject}&body=${emailBody}`;
---

<section class="section contact-panel" aria-labelledby="contact-panel-heading">
  <div class="container">
    <div class="contact-panel__header">
      <p class="eyebrow">{eyebrow}</p>
      <h2 id="contact-panel-heading">{title}</h2>
      <p class="lead">{text}</p>
    </div>

    <div class="grid contact-panel__grid">
      <section class="card contact-panel__details" aria-labelledby="contact-details-heading">
        <div class="contact-panel__advisor">
          <img
            src={site.advisor.image.src}
            alt={site.advisor.image.alt}
            width="128"
            height="128"
            loading="lazy"
            decoding="async"
          />
          <div>
            <p class="contact-panel__advisor-kicker">{contactCopy.advisorKicker}</p>
            <h3 id="contact-details-heading">{contactCopy.detailsHeading}</h3>
          </div>
        </div>
        <address>
          <a href={site.phoneHref}>{site.phone}</a>
          <a href={site.emailHref}>{site.email}</a>
          <span>{site.address.street}</span>
          <span>{addressLine}</span>
        </address>
        <p>{site.nmls}</p>
      </section>

      <section class="card contact-panel__prompt" aria-labelledby="contact-prompt-heading">
        <h3 id="contact-prompt-heading">{contactCopy.promptHeading}</h3>
        <p>{contactCopy.promptText}</p>
        <div class="actions contact-panel__actions">
          <a class="button" href={site.phoneHref}>{contactCopy.callLabel}</a>
          <a class="button button--secondary" href={guidanceEmailHref}>{contactCopy.emailLabel}</a>
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  .contact-panel__header {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .contact-panel__header h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .contact-panel__header .lead {
    margin: 14px 0 0;
  }

  .contact-panel__grid {
    align-items: start;
  }

  .contact-panel__details {
    display: grid;
    gap: 18px;
  }

  .contact-panel__advisor {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .contact-panel__advisor img {
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    border: 3px solid #f2d68b;
    border-radius: 50%;
    object-fit: cover;
    object-position: 50% 32%;
  }

  .contact-panel__advisor-kicker {
    color: var(--color-secondary);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .contact-panel__details h3,
  .contact-panel__details p {
    margin: 0;
  }

  .contact-panel__details address {
    display: grid;
    gap: 10px;
    color: var(--color-muted);
    font-style: normal;
  }

  .contact-panel__details p {
    color: var(--color-muted);
    font-weight: 750;
  }

  .contact-panel__prompt {
    display: grid;
    align-content: start;
    gap: 18px;
  }

  .contact-panel__prompt h3,
  .contact-panel__prompt p {
    margin: 0;
  }

  .contact-panel__prompt p {
    color: var(--color-muted);
  }
</style>
