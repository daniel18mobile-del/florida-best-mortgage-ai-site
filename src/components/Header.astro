---
import { primaryNav } from '@data/navigation';
import { site } from '@data/site';

const pathname = Astro.url.pathname;
const isSpanishPage = pathname === '/es/' || pathname.startsWith('/es/');
const spanishNavItems = [
  { key: 'home', label: 'Inicio', href: '/es/' },
  { key: 'services', label: 'Servicios', href: '/es/services/' },
  { key: 'calculadoras', label: 'Calculadoras', href: '/es/calculators/' },
  { key: 'about', label: 'Nosotros', href: '/es/about/' },
  { key: 'blog', label: 'Blog', href: '/es/blog/' },
  { key: 'contact', label: 'Contacto', href: '/es/contact/' }
];
const navItems = isSpanishPage
  ? spanishNavItems
  : primaryNav.map((item) => ({ ...item, key: item.label.toLowerCase() }));

const spanishRoutes = new Set(['/about/', '/blog/', '/calculators/', '/contact/', '/services/']);
const languageHref = (() => {
  if (isSpanishPage) {
    const englishPath = pathname.replace(/^\/es/, '') || '/';
    return englishPath === '' ? '/' : englishPath;
  }

  if (spanishRoutes.has(pathname) || pathname.startsWith('/services/')) {
    return `/es${pathname}`;
  }

  return '/es/';
})();

const languageLabel = isSpanishPage ? 'English' : 'Espanol';
const brandHref = isSpanishPage ? '/es/' : '/';
const brandAriaLabel = isSpanishPage ? `${site.name} inicio en Espanol` : `${site.name} home`;
const brandTagline = isSpanishPage ? 'Orientacion hipotecaria en Florida' : 'Florida mortgage guidance';
const skipLabel = isSpanishPage ? 'Saltar al contenido' : 'Skip to content';
const navAriaLabel = isSpanishPage ? 'Navegacion principal' : 'Primary navigation';
const actionsAriaLabel = isSpanishPage ? 'Opciones de contacto' : 'Contact actions';
const phoneAriaLabel = isSpanishPage ? `Llamar a ${site.name} al ${site.phone}` : `Call ${site.name} at ${site.phone}`;
const contactAriaLabel = isSpanishPage ? `Contactar a ${site.name}` : `Contact ${site.name}`;
const contactHref = isSpanishPage ? '/es/contact/' : '/contact/';
const contactLabel = isSpanishPage ? 'Contacto' : 'Contact';
---

<header class="site-header">
  <div class="site-header__top">
    <div class="container site-header__top-inner">
      <span>{site.nmls}</span>
      <a href={site.emailHref}>{site.email}</a>
    </div>
  </div>
  <div class="container site-header__inner">
    <a class="skip-link" href="#main-content">{skipLabel}</a>
    <a class="site-brand" href={brandHref} aria-label={brandAriaLabel}>
      <span class="site-brand__mark" aria-hidden="true">DF</span>
      <span class="site-brand__text">
        <span>{site.name}</span>
        <small>{brandTagline}</small>
      </span>
    </a>
    <nav class="site-nav" aria-label={navAriaLabel}>
      <ul class="site-nav__list">
        {navItems.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="site-header__actions" aria-label={actionsAriaLabel}>
      <a
        class:list={['site-header__language', { 'site-header__language--active': !isSpanishPage }]}
        href={languageHref}
        aria-label={isSpanishPage ? 'Switch to English' : 'Ver sitio en Espanol'}
        aria-current={!isSpanishPage ? 'page' : undefined}
      >
        {languageLabel}
      </a>
      <a class="site-header__phone" href={site.phoneHref} aria-label={phoneAriaLabel}>
        {site.phone}
      </a>
      <a class="button site-header__action" href={contactHref} aria-label={contactAriaLabel}>
        {contactLabel}
      </a>
    </div>
  </div>
</header>
