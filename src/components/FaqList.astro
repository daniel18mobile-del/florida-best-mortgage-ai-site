---
type Faq = {
  question: string;
  answer: string;
};

type Props = {
  eyebrow?: string;
  title?: string;
  lead?: string;
  faqs: Faq[];
};

const { eyebrow, title = 'Frequently asked questions', lead, faqs } = Astro.props;
const hasFaqs = faqs.length > 0;
---

{hasFaqs && (
  <section class="section faq-list" aria-labelledby="faq-list-heading">
    <div class="container faq-list__inner">
      <div class="faq-list__header">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h2 id="faq-list-heading">{title}</h2>
        {lead && <p class="lead">{lead}</p>}
      </div>

      <div class="faq-list__items">
        {faqs.map((faq) => (
          <details class="faq-list__item">
            <summary>{faq.question}</summary>
            <div class="faq-list__answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .faq-list__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1fr);
    gap: clamp(24px, 5vw, 56px);
    align-items: start;
  }

  .faq-list__header h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .faq-list__header .lead {
    margin: 14px 0 0;
  }

  .faq-list__items {
    display: grid;
    gap: 12px;
  }

  .faq-list__item {
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    box-shadow: var(--shadow-card);
  }

  .faq-list__item summary {
    cursor: pointer;
    font-weight: 800;
    padding: 18px 20px;
  }

  .faq-list__answer {
    border-top: 1px solid var(--color-line);
    color: var(--color-muted);
    padding: 0 20px 18px;
  }

  .faq-list__answer p {
    margin: 14px 0 0;
  }

  @media (max-width: 820px) {
    .faq-list__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
